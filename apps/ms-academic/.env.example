# Copy this file to .env and fill in real values. Never commit .env.
# F15: when running via docker-compose, use container name; for local dev use localhost
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=admin
DATABASE_PASSWORD=CHANGE_ME
DATABASE_NAME=gestor_escolar

# Must be the same value as ms-identity JWT_SECRET
JWT_SECRET=CHANGE_ME_32_CHARS_MIN

PORT=3002
