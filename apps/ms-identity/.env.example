# Copy this file to .env and fill in real values. Never commit .env.
# F15: use container name in docker-compose, localhost for direct dev
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=admin
DATABASE_PASSWORD=CHANGE_ME
DATABASE_NAME=gestor_escolar

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_32_CHARS_MIN

# Rotate these in Google Cloud Console if they were ever committed to git
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

RABBITMQ_URL=amqp://rabbitmq:5672

# F24: Redis for refresh token storage
REDIS_HOST=redis
REDIS_PORT=6379

# Runtime config
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Leave empty in dev; set to .yourdomain.com in production
COOKIE_DOMAIN=
PORT=3001
