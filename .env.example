# ============================================================
# GestorEscolar — Root .env.example (docker-compose variables)
# Copy to .env and fill in real values before running compose.
# NEVER commit .env to git.
# ============================================================

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=gestor_escolar

# RabbitMQ
RABBITMQ_USER=gestor_user
RABBITMQ_PASS=change_me_rabbitmq_password

# Grafana
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# Kong JWT (must match JWT_SECRET in ms-identity)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KONG_JWT_SECRET=change_me_jwt_secret_min_32_chars

# Frontend URL (used by Kong CORS and microservice CORS)
FRONTEND_URL=http://localhost:5173
